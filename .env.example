# Meta Instagram Messaging API
INSTAGRAM_ACCESS_TOKEN=   # User access token with instagram_business_manage_messages scope
INSTAGRAM_VERIFY_TOKEN=   # Any string you choose (e.g. "mysecrettoken") — must match Meta webhook config

# AI Model (OpenRouter)
OPENROUTER_API_KEY=       # API key from openrouter.ai
AI_MODEL=google/gemma-3-12b-it:free  # Primary model; fallback chain kicks in on 429/404

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Sheets (publish sheet as CSV: File → Share → Publish to web → CSV)
GOOGLE_SHEETS_PRICES_URL=   # e.g. https://docs.google.com/spreadsheets/d/.../export?format=csv

# App Config
PORT=3001
NEXT_PUBLIC_APP_URL=http://localhost:3001
